---
interface Deck {
  name: string;
  image: string;
}

interface Props {
  decks: Deck[];
}

const { decks } = Astro.props;
---

<section id="decks" class="section">
  <div class="container">
    <h2>Decks</h2>

    <div class="deck-photos-section">
      <div class="decks-grid">
      {decks.map(deck => (
        <div class="deck-photo">
          <img src={deck.image} alt={deck.name} loading="lazy" />
          <h3>{deck.name}</h3>
        </div>
      ))}
      </div>
    </div>

    <div class="video-section">
      <h4>Video Content</h4>
      <div class="videos-grid">
        <div class="video-embed">
          <iframe
            src="https://www.youtube.com/embed/videoseries?list=PLrpPol5WEyYE6Ybrx2UZwlX5e-7FAgxvc"
            title="Legacy Playlist - Gameplay from 2016"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <div class="video-embed">
          <iframe
            src="https://www.youtube.com/embed/videoseries?list=PLrpPol5WEyYGhxAFnmaSjlf8lVOR8iRCx"
            title="Legacy Playlist 2 - Gameplay from 2016"
